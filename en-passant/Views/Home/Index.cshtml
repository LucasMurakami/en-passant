@using en_passant.Services
@using en_passant.Models
@using en_passant.Controllers
@using en_passant.Models.Enum

@model en_passant.Services.Interface.IStockService


@{
    ViewData["Title"] = "Storage Page";

    var searchTerm = (ViewContext.HttpContext.Request.Query["searchTerm"].ToString() ?? "").ToLower();
    var categoryFilter = (ViewContext.HttpContext.Request.Query["category"].ToString() ?? "").ToLower();
    
    Category categoryEnum;
    var isValidCategory = Enum.TryParse(categoryFilter, true, out categoryEnum);
    var filteredGames = Model.GetAll()
        .Where(j => (string.IsNullOrEmpty(searchTerm) || j.Game.Name.ToLower().Contains(searchTerm.ToLower())) &&
                    (!isValidCategory || j.Game.Category == categoryEnum))
        .ToList();

    var page = int.TryParse(ViewContext.HttpContext.Request.Query["page"], out var p) ? p : 1;
    var pageSize = 5;
    var totalItems = filteredGames.Count;
    var totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
  

    var pagedGames = filteredGames
        .Skip((page - 1) * pageSize)
        .Take(pageSize)
        .ToList();
    
    var currentPage = page;
}

<link rel="stylesheet" href="~/css/View/Home/Index.css" asp-append-version="true"/>

<div class="container-table">
    <div class="table-wrapper">
        <table class="custom-table">
            <thead class="font-roboto font-bold">
            <tr>
                <th>Jogo</th>
                <th>Categoria</th>
                <th>Tipo</th>
                <th>Quantidade</th>
                <th>Ações</th>
            </tr>
            </thead>
            <tbody class="font-roboto font-bold">
            @for (int i = 0; i < pagedGames.Count; i++)
            {
                var jogo = pagedGames[i];
                bool isOdd = i % 2 == 0; // Razor index starts at 0

                <tr>
                    <td>@jogo.Game.Name</td>
                    <td>@jogo.Game.Category.GetDisplayName()</td>
                    <td>@jogo.Game.GameType.GetDisplayName()</td>
                    <td>@jogo.Quantity</td>
                    <td>
                        <button class="btn" onclick="">
                            <img class="image-box" src="~/assets/icons/@(isOdd ? "add-white.svg" : "add-black.svg")"/>
                        </button>
                        <button class="btn" onclick="toggleModalEditGame(@(jogo.Game.Id))">
                            <img class="image-box" src="~/assets/icons/@(isOdd ? "edit-white.svg" : "edit-black.svg")"/>
                        </button>
                        <button class="btn">
                            <img class="image-box" src="~/assets/icons/@(isOdd ? "delete-white.svg" : "delete-black.svg")"/>
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="pagination-container">
    <div class="pagination">
        @{
            int maxVisiblePages = 5;
            int startPage = Math.Max(1, page - 2);
            int endPage = Math.Min(totalPages, startPage + maxVisiblePages - 1);

            if (startPage > 1)
            {
                <a href="?page=1&searchTerm=@searchTerm&category=@categoryFilter">1</a>
                <span class="dots" onclick="togglePageInput()">...</span>
            }

            for (int i = startPage; i <= endPage; i++)
            {
                <a href="?page=@i&searchTerm=@searchTerm&category=@categoryFilter"
                   class="@(i == page ? "active" : "")">@i</a>
            }

            if (endPage < totalPages)
            {
                <span class="dots" onclick="togglePageInput()">...</span>
                <a href="?page=@totalPages&searchTerm=@searchTerm&category=@categoryFilter">@totalPages</a>
            }
        }

    </div>
</div>

<div id="pageModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModalPage()">&times;</span>
        <h3>Ir para página</h3>
        <form id="pageForm" method="get" action="" class="font-roboto font-bold" >
            <input type="number" id="pageInput" name="page" min="1" max="@totalPages" placeholder="Número da página">
            <input type="hidden" name="searchTerm" value="@searchTerm">
            <input type="hidden" name="category" value="@categoryFilter">
            <button type="submit">Ir</button>
        </form>
    </div>
</div>

<div id="modalEditGame" class="modal"></div>
<div id="modalAddGame" class="modal"></div>


<script>
    function toggleModalEditGame(id) {
        fetch(`/Game/EditGame/${id}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById("modalEditGame").innerHTML = html;
                document.getElementById("modalEditGame").style.display = "block";
            });
    }

    function closeModalEditGame() {
        document.getElementById("modalEditGame").style.display = "none";
    }
    
</script>

<script>
    function togglePageInput() {
        const modal = document.getElementById("pageModal");
        modal.style.display = "block";
    }

    function closeModalPage() {
        const modal = document.getElementById("pageModal");
        modal.style.display = "none";
    }

    window.onclick = function(event) {
        const modal = document.getElementById("pageModal");
        if (event.target === modal) {
            modal.style.display = "none";
        }
    }

    // REGEX for Modal Page -> Page Validation and Number Regex
    document.getElementById("pageForm").addEventListener("submit", function (e) {
        e.preventDefault();

        const input = document.getElementById("pageInput");
        const inputValue = input.value.trim();

        const maxPage = parseInt('@totalPages');
        const currentPage = parseInt('@currentPage');
        const searchTerm = '@searchTerm';
        const category = '@categoryFilter';

        const isValidInteger = /^[1-9]\d*$/.test(inputValue);

        let page;

        if (!isValidInteger) {
            page = currentPage;
        } else {
            page = parseInt(inputValue);
            page = Math.max(1, Math.min(page, maxPage));
        }

        window.location.href = `?page=${page}&searchTerm=${encodeURIComponent(searchTerm)}&category=${encodeURIComponent(category)}`;
    });
    
    // REGEX for Modal Page -> ShortCuts
    const pageInput = document.getElementById("pageInput");

    pageInput.addEventListener("keydown", function (e) {
        // Permitir apenas números (0–9), backspace, delete, setas
        const allowedKeys = [
            'Backspace', 'Delete', 'ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Tab'
        ];

        const isNumberKey = /^[0-9]$/.test(e.key);

        if (!isNumberKey && !allowedKeys.includes(e.key)) {
            e.preventDefault();
        }   
    });
</script>